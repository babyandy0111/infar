# [資料庫設定]
DB_PASSWORD=InfarDbPass123
REDIS_PASSWORD=InfarDbPass123
CLICKHOUSE_PASSWORD=InfarCHPass123
DB_USER=admin
DB_NAME=infar_db
CLICKHOUSE_USER=infar_admin
CLICKHOUSE_DB=infar_iot

# [ArgoCD 設定]
ARGOCD_ADMIN_PASSWORD=your_argocd_password

# [GCP 設定]
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=asia-east1

# [AWS 設定]
AWS_REGION=ap-northeast-1
AWS_CLUSTER_NAME=infar-cloud-eks

# [雲端 Endpoint] (手動套用 setup.sh aws/gcp 時使用)
# DB_ENDPOINT=rds-postgres.xxxx.rds.amazonaws.com
# REDIS_ENDPOINT=elasticache-redis.xxxx.cache.amazonaws.com
